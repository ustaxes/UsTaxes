{
  "openapi": "3.1.0",
  "info": {
    "title": "UsTaxes Return Data Schema",
    "version": "1.0.0",
    "description": "Unified JSON schema for UsTaxes return data. Data sources may provide partial information."
  },
  "components": {
    "schemas": {
      "ReturnPayload": {
        "type": "object",
        "required": ["taxYear", "information"],
        "properties": {
          "taxYear": {
            "$ref": "#/components/schemas/TaxYear"
          },
          "information": {
            "$ref": "#/components/schemas/Information"
          }
        },
        "additionalProperties": false,
        "patternProperties": {
          "^.+_source$": {
            "$ref": "#/components/schemas/FieldSource"
          }
        }
      },
      "ReturnBundle": {
        "type": "object",
        "required": ["returns"],
        "properties": {
          "version": {
            "type": "string",
            "description": "Schema version for the bundle container."
          },
          "returns": {
            "type": "object",
            "description": "Map of tax year (e.g., Y2023) to return payloads.",
            "additionalProperties": {
              "$ref": "#/components/schemas/ReturnPayload"
            }
          },
          "activeYear": { "$ref": "#/components/schemas/TaxYear" },
          "assets": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Asset" }
          }
        },
        "additionalProperties": false
      },
      "TaxPayer": {
        "type": "object",
        "required": ["primaryPerson", "dependents"],
        "properties": {
          "filingStatus": {
            "type": "string",
            "enum": ["S", "MFJ", "MFS", "HOH", "W"]
          },
          "primaryPerson": {
            "$ref": "#/components/schemas/Person"
          },
          "spouse": {
            "$ref": "#/components/schemas/Person"
          },
          "dependents": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Dependent"
            }
          },
          "contactEmail": {
            "type": "string"
          },
          "contactPhoneNumber": {
            "type": "string"
          }
        },
        "additionalProperties": false,
        "patternProperties": {
          "^.+_source$": {
            "$ref": "#/components/schemas/FieldSource"
          }
        }
      },
      "Person": {
        "type": "object",
        "required": [
          "firstName",
          "lastName",
          "ssid",
          "role",
          "isBlind",
          "dateOfBirth"
        ],
        "properties": {
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "ssid": {
            "type": "string",
            "description": "9 digits or NRA for a nonresident spouse if provided."
          },
          "role": {
            "type": "string",
            "enum": ["PRIMARY", "SPOUSE", "DEPENDENT", "EMPLOYER"]
          },
          "isBlind": {
            "type": "boolean"
          },
          "dateOfBirth": {
            "type": "string",
            "format": "date"
          },
          "address": {
            "$ref": "#/components/schemas/Address"
          },
          "isTaxpayerDependent": {
            "type": "boolean"
          }
        },
        "additionalProperties": false,
        "patternProperties": {
          "^.+_source$": {
            "$ref": "#/components/schemas/FieldSource"
          }
        }
      },
      "Dependent": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Person"
          },
          {
            "type": "object",
            "required": ["relationship"],
            "properties": {
              "relationship": {
                "type": "string"
              },
              "qualifyingInfo": {
                "type": "object",
                "properties": {
                  "numberOfMonths": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 12
                  },
                  "isStudent": {
                    "type": "boolean"
                  }
                },
                "additionalProperties": false,
                "patternProperties": {
                  "^.+_source$": {
                    "$ref": "#/components/schemas/FieldSource"
                  }
                }
              }
            },
            "patternProperties": {
              "^.+_source$": {
                "$ref": "#/components/schemas/FieldSource"
              }
            }
          }
        ]
      },
      "Address": {
        "type": "object",
        "required": ["address", "city"],
        "properties": {
          "address": {
            "type": "string"
          },
          "aptNo": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "$ref": "#/components/schemas/State"
          },
          "zip": {
            "type": "string"
          },
          "foreignCountry": {
            "type": "string"
          },
          "province": {
            "type": "string"
          },
          "postalCode": {
            "type": "string"
          }
        },
        "additionalProperties": false,
        "patternProperties": {
          "^.+_source$": {
            "$ref": "#/components/schemas/FieldSource"
          }
        }
      },
      "Employer": {
        "type": "object",
        "properties": {
          "EIN": {
            "type": "string"
          },
          "employerName": {
            "type": "string"
          },
          "address": {
            "$ref": "#/components/schemas/Address"
          }
        },
        "additionalProperties": false,
        "patternProperties": {
          "^.+_source$": {
            "$ref": "#/components/schemas/FieldSource"
          }
        }
      },
      "W2Box12Info": {
        "type": "object",
        "patternProperties": {
          "^[A-Z0-9]{1,3}$": {
            "type": "number"
          },
          "^[A-Z0-9]{1,3}_source$": {
            "$ref": "#/components/schemas/FieldSource"
          }
        },
        "additionalProperties": false,
        "description": "Map of W-2 box 12 codes to amounts, e.g. {\"D\": 1500}."
      },
      "W2": {
        "type": "object",
        "required": [
          "occupation",
          "income",
          "medicareIncome",
          "fedWithholding",
          "ssWages",
          "ssWithholding",
          "medicareWithholding",
          "personRole"
        ],
        "properties": {
          "occupation": {
            "type": "string"
          },
          "income": {
            "type": "number"
          },
          "medicareIncome": {
            "type": "number"
          },
          "fedWithholding": {
            "type": "number"
          },
          "ssWages": {
            "type": "number"
          },
          "ssWithholding": {
            "type": "number"
          },
          "medicareWithholding": {
            "type": "number"
          },
          "employer": {
            "$ref": "#/components/schemas/Employer"
          },
          "personRole": {
            "type": "string",
            "enum": ["PRIMARY", "SPOUSE"]
          },
          "state": {
            "$ref": "#/components/schemas/State"
          },
          "stateWages": {
            "type": "number"
          },
          "stateWithholding": {
            "type": "number"
          },
          "box12": {
            "$ref": "#/components/schemas/W2Box12Info"
          }
        },
        "additionalProperties": false,
        "patternProperties": {
          "^.+_source$": {
            "$ref": "#/components/schemas/FieldSource"
          }
        }
      },
      "Income1099Int": {
        "type": "object",
        "required": ["type", "payer", "personRole", "form"],
        "properties": {
          "type": {
            "const": "INT"
          },
          "payer": {
            "type": "string"
          },
          "personRole": {
            "type": "string",
            "enum": ["PRIMARY", "SPOUSE"]
          },
          "form": {
            "type": "object",
            "required": ["income"],
            "properties": {
              "income": {
                "type": "number"
              }
            },
            "additionalProperties": false,
            "patternProperties": {
              "^.+_source$": {
                "$ref": "#/components/schemas/FieldSource"
              }
            }
          }
        },
        "additionalProperties": false,
        "patternProperties": {
          "^.+_source$": {
            "$ref": "#/components/schemas/FieldSource"
          }
        }
      },
      "Income1099Div": {
        "type": "object",
        "required": ["type", "payer", "personRole", "form"],
        "properties": {
          "type": {
            "const": "DIV"
          },
          "payer": {
            "type": "string"
          },
          "personRole": {
            "type": "string",
            "enum": ["PRIMARY", "SPOUSE"]
          },
          "form": {
            "type": "object",
            "required": [
              "dividends",
              "qualifiedDividends",
              "totalCapitalGainsDistributions"
            ],
            "properties": {
              "dividends": {
                "type": "number"
              },
              "qualifiedDividends": {
                "type": "number"
              },
              "totalCapitalGainsDistributions": {
                "type": "number"
              }
            },
            "additionalProperties": false,
            "patternProperties": {
              "^.+_source$": {
                "$ref": "#/components/schemas/FieldSource"
              }
            }
          }
        },
        "additionalProperties": false,
        "patternProperties": {
          "^.+_source$": {
            "$ref": "#/components/schemas/FieldSource"
          }
        }
      },
      "Income1099B": {
        "type": "object",
        "required": ["type", "payer", "personRole", "form"],
        "properties": {
          "type": {
            "const": "B"
          },
          "payer": {
            "type": "string"
          },
          "personRole": {
            "type": "string",
            "enum": ["PRIMARY", "SPOUSE"]
          },
          "form": {
            "type": "object",
            "required": [
              "shortTermProceeds",
              "shortTermCostBasis",
              "longTermProceeds",
              "longTermCostBasis"
            ],
            "properties": {
              "shortTermProceeds": {
                "type": "number"
              },
              "shortTermCostBasis": {
                "type": "number"
              },
              "longTermProceeds": {
                "type": "number"
              },
              "longTermCostBasis": {
                "type": "number"
              }
            },
            "additionalProperties": false,
            "patternProperties": {
              "^.+_source$": {
                "$ref": "#/components/schemas/FieldSource"
              }
            }
          }
        },
        "additionalProperties": false,
        "patternProperties": {
          "^.+_source$": {
            "$ref": "#/components/schemas/FieldSource"
          }
        }
      },
      "Income1099R": {
        "type": "object",
        "required": ["type", "payer", "personRole", "form"],
        "properties": {
          "type": {
            "const": "R"
          },
          "payer": {
            "type": "string"
          },
          "personRole": {
            "type": "string",
            "enum": ["PRIMARY", "SPOUSE"]
          },
          "form": {
            "type": "object",
            "required": [
              "grossDistribution",
              "taxableAmount",
              "federalIncomeTaxWithheld",
              "planType"
            ],
            "properties": {
              "grossDistribution": {
                "type": "number"
              },
              "taxableAmount": {
                "type": "number"
              },
              "federalIncomeTaxWithheld": {
                "type": "number"
              },
              "planType": {
                "type": "string",
                "enum": ["IRA", "RothIRA", "SepIRA", "SimpleIRA", "Pension"]
              }
            },
            "additionalProperties": false,
            "patternProperties": {
              "^.+_source$": {
                "$ref": "#/components/schemas/FieldSource"
              }
            }
          }
        },
        "additionalProperties": false,
        "patternProperties": {
          "^.+_source$": {
            "$ref": "#/components/schemas/FieldSource"
          }
        }
      },
      "Income1099SSA": {
        "type": "object",
        "required": ["type", "payer", "personRole", "form"],
        "properties": {
          "type": {
            "const": "SSA"
          },
          "payer": {
            "type": "string"
          },
          "personRole": {
            "type": "string",
            "enum": ["PRIMARY", "SPOUSE"]
          },
          "form": {
            "type": "object",
            "required": ["netBenefits", "federalIncomeTaxWithheld"],
            "properties": {
              "netBenefits": {
                "type": "number"
              },
              "federalIncomeTaxWithheld": {
                "type": "number"
              }
            },
            "additionalProperties": false,
            "patternProperties": {
              "^.+_source$": {
                "$ref": "#/components/schemas/FieldSource"
              }
            }
          }
        },
        "additionalProperties": false,
        "patternProperties": {
          "^.+_source$": {
            "$ref": "#/components/schemas/FieldSource"
          }
        }
      },
      "Income1099NEC": {
        "type": "object",
        "required": ["type", "payer", "personRole", "form"],
        "properties": {
          "type": {
            "const": "NEC"
          },
          "payer": {
            "type": "string"
          },
          "personRole": {
            "type": "string",
            "enum": ["PRIMARY", "SPOUSE"]
          },
          "form": {
            "type": "object",
            "required": ["nonemployeeCompensation"],
            "properties": {
              "nonemployeeCompensation": {
                "type": "number"
              }
            },
            "additionalProperties": false,
            "patternProperties": {
              "^.+_source$": {
                "$ref": "#/components/schemas/FieldSource"
              }
            }
          }
        },
        "additionalProperties": false,
        "patternProperties": {
          "^.+_source$": {
            "$ref": "#/components/schemas/FieldSource"
          }
        }
      },
      "Supported1099": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/Income1099Int"
          },
          {
            "$ref": "#/components/schemas/Income1099Div"
          },
          {
            "$ref": "#/components/schemas/Income1099B"
          },
          {
            "$ref": "#/components/schemas/Income1099R"
          },
          {
            "$ref": "#/components/schemas/Income1099SSA"
          },
          {
            "$ref": "#/components/schemas/Income1099NEC"
          }
        ],
        "discriminator": {
          "propertyName": "type",
          "mapping": {
            "INT": "#/components/schemas/Income1099Int",
            "DIV": "#/components/schemas/Income1099Div",
            "B": "#/components/schemas/Income1099B",
            "R": "#/components/schemas/Income1099R",
            "SSA": "#/components/schemas/Income1099SSA",
            "NEC": "#/components/schemas/Income1099NEC"
          }
        }
      },
      "F1098MortgageInterest": {
        "type": "object",
        "required": ["lender", "interest"],
        "properties": {
          "lender": {
            "type": "string"
          },
          "interest": {
            "type": "number",
            "description": "Home mortgage interest and points reported on Form 1098."
          },
          "points": {
            "type": "number",
            "description": "Points reported on Form 1098."
          },
          "mortgageInsurancePremiums": {
            "type": "number",
            "description": "Mortgage insurance premiums reported on Form 1098."
          }
        },
        "additionalProperties": false,
        "patternProperties": {
          "^.+_source$": {
            "$ref": "#/components/schemas/FieldSource"
          }
        }
      },
      "RentalProperty": {
        "type": "object",
        "required": [
          "address",
          "rentalDays",
          "personalUseDays",
          "rentReceived",
          "propertyType",
          "qualifiedJointVenture",
          "expenses"
        ],
        "properties": {
          "address": {
            "$ref": "#/components/schemas/Address"
          },
          "rentalDays": {
            "type": "number"
          },
          "personalUseDays": {
            "type": "number"
          },
          "rentReceived": {
            "type": "number"
          },
          "propertyType": {
            "type": "string",
            "enum": [
              "singleFamily",
              "multiFamily",
              "vacation",
              "commercial",
              "land",
              "selfRental",
              "other"
            ]
          },
          "isPassive": {
            "type": "boolean"
          },
          "otherPropertyType": {
            "type": "string"
          },
          "qualifiedJointVenture": {
            "type": "boolean"
          },
          "expenses": {
            "type": "object",
            "properties": {
              "advertising": { "type": "number" },
              "auto": { "type": "number" },
              "cleaning": { "type": "number" },
              "commissions": { "type": "number" },
              "insurance": { "type": "number" },
              "legal": { "type": "number" },
              "management": { "type": "number" },
              "mortgage": { "type": "number" },
              "otherInterest": { "type": "number" },
              "repairs": { "type": "number" },
              "supplies": { "type": "number" },
              "taxes": { "type": "number" },
              "utilities": { "type": "number" },
              "depreciation": { "type": "number" },
              "other": { "type": "number" }
            },
            "additionalProperties": false,
            "patternProperties": {
              "^.+_source$": {
                "$ref": "#/components/schemas/FieldSource"
              }
            }
          },
          "otherExpenseType": {
            "type": "string"
          }
        },
        "additionalProperties": false,
        "patternProperties": {
          "^.+_source$": {
            "$ref": "#/components/schemas/FieldSource"
          }
        }
      },
      "TaxYear": {
        "type": "string",
        "enum": ["Y2019", "Y2020", "Y2021", "Y2022", "Y2023", "Y2024"]
      },
      "AccountType": {
        "type": "string",
        "enum": ["checking", "savings"]
      },
      "Refund": {
        "type": "object",
        "required": ["routingNumber", "accountNumber", "accountType"],
        "properties": {
          "routingNumber": {
            "type": "string"
          },
          "accountNumber": {
            "type": "string"
          },
          "accountType": {
            "$ref": "#/components/schemas/AccountType"
          }
        },
        "additionalProperties": false,
        "patternProperties": {
          "^.+_source$": {
            "$ref": "#/components/schemas/FieldSource"
          }
        }
      },
      "EstimatedTaxPayment": {
        "type": "object",
        "required": ["label", "payment"],
        "properties": {
          "label": { "type": "string" },
          "payment": { "type": "number" }
        },
        "additionalProperties": false,
        "patternProperties": {
          "^.+_source$": {
            "$ref": "#/components/schemas/FieldSource"
          }
        }
      },
      "HealthSavingsAccount": {
        "type": "object",
        "required": [
          "label",
          "coverageType",
          "contributions",
          "personRole",
          "startDate",
          "endDate",
          "totalDistributions",
          "qualifiedDistributions"
        ],
        "properties": {
          "label": { "type": "string" },
          "coverageType": { "type": "string", "enum": ["self-only", "family"] },
          "contributions": { "type": "number" },
          "personRole": { "type": "string", "enum": ["PRIMARY", "SPOUSE"] },
          "startDate": { "type": "string", "format": "date" },
          "endDate": { "type": "string", "format": "date" },
          "totalDistributions": { "type": "number" },
          "qualifiedDistributions": { "type": "number" }
        },
        "additionalProperties": false
      },
      "IraPlanType": {
        "type": "string",
        "enum": ["IRA", "RothIRA", "SepIRA", "SimpleIRA"]
      },
      "Ira": {
        "type": "object",
        "required": [
          "payer",
          "personRole",
          "grossDistribution",
          "taxableAmount",
          "taxableAmountNotDetermined",
          "totalDistribution",
          "federalIncomeTaxWithheld",
          "planType",
          "contributions",
          "rolloverContributions",
          "rothIraConversion",
          "recharacterizedContributions",
          "requiredMinimumDistributions",
          "lateContributions",
          "repayments"
        ],
        "properties": {
          "payer": { "type": "string" },
          "personRole": { "type": "string", "enum": ["PRIMARY", "SPOUSE"] },
          "grossDistribution": { "type": "number" },
          "taxableAmount": { "type": "number" },
          "taxableAmountNotDetermined": { "type": "boolean" },
          "totalDistribution": { "type": "boolean" },
          "federalIncomeTaxWithheld": { "type": "number" },
          "planType": { "$ref": "#/components/schemas/IraPlanType" },
          "contributions": { "type": "number" },
          "rolloverContributions": { "type": "number" },
          "rothIraConversion": { "type": "number" },
          "recharacterizedContributions": { "type": "number" },
          "requiredMinimumDistributions": { "type": "number" },
          "lateContributions": { "type": "number" },
          "repayments": { "type": "number" }
        },
        "additionalProperties": false
      },
      "Property": {
        "$ref": "#/components/schemas/RentalProperty"
      },
      "BusinessIncome": {
        "type": "object",
        "required": ["grossReceipts", "returnsAndAllowances"],
        "properties": {
          "grossReceipts": { "type": "number" },
          "returnsAndAllowances": { "type": "number" },
          "otherIncome": { "type": "number" }
        },
        "additionalProperties": false,
        "patternProperties": {
          "^.+_source$": {
            "$ref": "#/components/schemas/FieldSource"
          }
        }
      },
      "BusinessExpenses": {
        "type": "object",
        "properties": {
          "advertising": { "type": "number" },
          "carAndTruck": { "type": "number" },
          "commissions": { "type": "number" },
          "contractLabor": { "type": "number" },
          "depletion": { "type": "number" },
          "depreciation": { "type": "number" },
          "employeeBenefit": { "type": "number" },
          "insurance": { "type": "number" },
          "interestMortgage": { "type": "number" },
          "interestOther": { "type": "number" },
          "legalAndProfessional": { "type": "number" },
          "office": { "type": "number" },
          "pensionProfitSharing": { "type": "number" },
          "rentVehicles": { "type": "number" },
          "rentOther": { "type": "number" },
          "repairs": { "type": "number" },
          "supplies": { "type": "number" },
          "taxesAndLicenses": { "type": "number" },
          "travel": { "type": "number" },
          "meals": { "type": "number" },
          "utilities": { "type": "number" },
          "wages": { "type": "number" },
          "other": { "type": "number" }
        },
        "additionalProperties": false,
        "patternProperties": {
          "^.+_source$": {
            "$ref": "#/components/schemas/FieldSource"
          }
        }
      },
      "Business": {
        "type": "object",
        "required": ["name", "income", "expenses"],
        "properties": {
          "name": { "type": "string" },
          "principalBusinessOrProfession": { "type": "string" },
          "businessCode": { "type": "string" },
          "ein": { "type": "string" },
          "address": { "$ref": "#/components/schemas/Address" },
          "income": { "$ref": "#/components/schemas/BusinessIncome" },
          "expenses": { "$ref": "#/components/schemas/BusinessExpenses" },
          "otherExpenseType": { "type": "string" },
          "otherExpenseAmount": { "type": "number" },
          "homeOfficeDeduction": { "type": "number" }
        },
        "additionalProperties": false,
        "patternProperties": {
          "^.+_source$": {
            "$ref": "#/components/schemas/FieldSource"
          }
        }
      },
      "F1098e": {
        "type": "object",
        "required": ["lender", "interest"],
        "properties": {
          "lender": { "type": "string" },
          "interest": { "type": "number" }
        },
        "additionalProperties": false
      },
      "F3921": {
        "type": "object",
        "required": [
          "name",
          "personRole",
          "exercisePricePerShare",
          "fmv",
          "numShares"
        ],
        "properties": {
          "name": { "type": "string" },
          "personRole": { "type": "string", "enum": ["PRIMARY", "SPOUSE"] },
          "exercisePricePerShare": { "type": "number" },
